{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",

    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@app/*": ["src/app/*"],
      "@assets/*": ["assets/*"],
      "@features/*": ["src/features/*"],
      "@hooks/*": ["src/hooks/*"]
    }
  }
}
